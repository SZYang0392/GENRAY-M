SHELL=		/bin/sh
NAME=		xgenray_mpi.gfortran64
# 检测可用的 MPI 编译器
ifeq ($(shell which mpiifort >/dev/null 2>&1; echo $$?),0)
	COMPILER := mpiifort -fallow-argument-mismatch
else ifeq ($(shell which mpif90 >/dev/null 2>&1; echo $$?),0)
	COMPILER := mpif90 -fallow-argument-mismatch
else
	$(error No compatible MPI compiler found! Install Intel MPI or OpenMPI)
endif
BUILDER=	$(COMPILER)
