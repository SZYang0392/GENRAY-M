OBJECTS=	$(SOURCES:.f=.o)
MPIOBJS=	$(SOURCES:.f=.mpio)
F90SRCS=	kind_spec.f90 const_and_precisions.f90 quanc8.f90 config_ext.f90 green_func_ext.f90
F90OBJS=	$(F90SRCS:.f90=.o)


# 获取真实路径
NC_CONFIG := $(shell readlink -f `which nc-config` 2>/dev/null || which nc-config)
NF_CONFIG := $(shell readlink -f `which nf-config` 2>/dev/null || which nf-config)
# 提取netCDF根目录
NETCDF_C_HOME := $(patsubst %/bin/nc-config,%,$(NC_CONFIG))
NETCDF_FORTRAN_HOME := $(patsubst %/bin/nf-config,%,$(NF_CONFIG))
# netCDF路径验证
ifeq ($(NETCDF_C_HOME),)
 	$(error netCDF C library not found. Check if nc-config is in PATH)
endif
ifeq ($(NETCDF_FORTRAN_HOME),)
	$(error netCDF Fortran library not found. Check if nf-config is in PATH)
endif
# netCDF调试信息
$(info netCDF C home: $(NETCDF_C_HOME))
$(info netCDF Fortran home: $(NETCDF_FORTRAN_HOME))


# hostname:= $(shell echo $(HOSTNAME))
LOCATION= -L/usr/lib64  -L$(PGPLOT_DIR) -L$(NETCDF_FORTRAN_HOME)/lib -lnetcdff \
	-L$(NETCDF_C_HOME)/lib -lnetcdf -L$(MPI_ROOT)/lib
LIBRARIES=	$(LOCATION) 	-lnetcdff -lnetcdf -lpgplot
#Location of netcdf.inc:
#Includes netcdf.inc and mpif.h(for mpi): Evidently need -I for each include.
INCLUDE= -I/usr/include/ -I$(PGPLOT_DIR) -I$(NETCDF_C_HOME)/include \
	-I$(NETCDF_FORTRAN_HOME)/include -I$(MPI_ROOT)/include



DEBUG=		
CSPECIAL= -O3z -fno-align-commons
BSPECIAL=	

#COMPILE=	$(COMPILER) -c $(CSPECIAL) $(DEBUG) -I $(INCLUDE)
COMPILE=	$(COMPILER) -c $(CSPECIAL) $(INCLUDE)
#BUILD=		$(BUILDER) -o $(NAME) $(BSPECIAL) $(DEBUG)
BUILD=		$(BUILDER) -o $(NAME) $(BSPECIAL)
PROTECT=	chmod 755
DELETE=		rm -f

# 方案：直接在工作目录操作，避免移动文件
$(NAME): $(F90OBJS) $(MPIOBJS) genray_par.mpio
	# 重命名mpio->o
	for f in *.mpio; do mv "$$f" "$${f%.mpio}.o"; done
	# 链接可执行文件
	$(BUILDER) -o $(NAME) *.o $(LIBRARIES)
	chmod 755 $(NAME)
	# 恢复原始扩展名
	for f in *.o; do mv "$$f" "$${f%.o}.mpio"; done

$(SOURCES):        $(INCLUDES)

$(F90OBJS): %.o: %.f90
	$(COMPILER) $< -c
#	$(COMPILER) $< -c $@

$(MPIOBJS): %.mpio: %.f 
	cp $< temp_mpi.f
	mpi/cmm -a temp_mpi.f
	mpi/cmm -p WRITE "write(*," temp_mpi.f
	mpi/cmm -p PAUSE "pause" temp_mpi.f
	mpi/cmm -p PRINT " print " temp_mpi.f
	$(COMPILER) -c temp_mpi.f $(INCLUDE) -o temp_mpi.o
	mv temp_mpi.o $@
	rm -f temp_mpi.f

genray_par.mpio:	genray.f mpi/mpi.ins
	cp genray.f temp_mpi.f
	mpi/cmm -a temp_mpi.f
	mpi/cmm -p WRITE "write(*," temp_mpi.f
	mpi/cmm -p PAUSE "pause" temp_mpi.f
	mpi/cmm -p PRINT " print " temp_mpi.f
	mpi/auto temp_mpi.f mpi/mpi.ins >genray_par.f
	$(COMPILER) -c genray_par.f $(INCLUDE) -o temp_mpi.o
	mv temp_mpi.o genray_par.mpio
	rm -f temp_mpi.f
	cp kind_spec.o kind_spec.mpio
	cp const_and_precisions.o const_and_precisions.mpio
	cp quanc8.o quanc8.mpio
	cp config_ext.o config_ext.mpio
	cp green_func_ext.o green_func_ext.mpio

clean:	
	rm -rf *.mpio temp_mpi* TMP *.o *.mod \
	genray_par.f | echo -n

